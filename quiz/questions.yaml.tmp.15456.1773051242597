        text_nl: "75%"
        correct: true
        feedback_en: "Correct! 90 / 120 × 100% = 75%."
        feedback_nl: "Correct! 90 / 120 × 100% = 75%."
      - text_en: "100%"
        text_nl: "100%"
        correct: false
        feedback_en: "Incorrect. 100% would mean all 120 people drink cola. Only 90 do."
        feedback_nl: "Onjuist. 100% zou betekenen dat alle 120 mensen cola drinken. Slechts 90 doen dat."
      - text_en: "90%"
        text_nl: "90%"
        correct: false
        feedback_en: "Incorrect. 90 is the count, not the percentage. Percentage = (90 / 120) × 100 = 75%."
